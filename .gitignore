node_modules/
.DS_Store
.claude/

# Playwright: track spec sources + config + snapshot baselines, but
# ignore runtime artifacts (reports, traces, results, videos).
# The e2e tests are the source of truth for CI so the source files MUST
# be checked in. Only transient outputs stay local.
e2e/test-results/
e2e/playwright-report/
e2e/results.json

# Top-level Playwright outputs (when run from web/ root, not e2e/)
test-results/
playwright-report/

# TestSprite runtime outputs — spec sources tracked, runtime tmp ignored
testsprite_tests/tmp/

# npm lockfile — this repo has no build step; package.json is for
# Playwright-only dev deps and the lockfile is regeneratable, but it
# should not be checked in alongside a static-deploy site.
package-lock.json

serve.js
*.log

# Deploy secrets — never commit the real .env.deploy
.env
.env.deploy
.env.local

# Deploy artifacts: scripts/deploy.sh stamps `?v=<sha>` cache-busters
# in-place and writes *.deploy-bak alongside before the FTP upload. The
# script restores them post-deploy, but a failed run can leave them
# behind. They're never source-of-truth — always regeneratable.
*.deploy-bak

.mcp.json

# Homepage placeholder photos — operator drops licensed photos in
# locally; we don't want them accidentally shipped via git. Only the
# README that documents the filename contract is tracked.
assets/images/placeholders/*.jpg
assets/images/placeholders/*.jpeg
assets/images/placeholders/*.png
assets/images/placeholders/*.webp
!assets/images/placeholders/README.md

# Per-artist photos for the directory + EPK pages. Same drop-zone
# pattern as placeholders/. Filename = slugged stage_name + .jpg.
assets/images/artists/*.jpg
assets/images/artists/*.jpeg
assets/images/artists/*.png
assets/images/artists/*.webp
!assets/images/artists/README.md
*.deploy-bak

# Sourcemaps from the esbuild minify step in scripts/deploy-stamp.sh.
# Created during deploy, restored by cleanup_stamps in deploy.sh, but
# ignored anyway in case of crash mid-deploy.
assets/js/*.js.map
