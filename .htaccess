# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security headers
<IfModule mod_headers.c>
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set X-XSS-Protection "1; mode=block"
  # CSP rationale — only widened to what the app actually needs:
  #   script-src: jsDelivr for Supabase SDK, Plausible for privacy-friendly analytics.
  #   style-src:  Fontshare + Google Fonts stylesheets for Chillax / Satoshi / JetBrains Mono.
  #   font-src:   The actual .woff2 payloads the above stylesheets reference.
  #   connect-src: Supabase API + realtime WebSocket, plus Plausible event endpoint.
  #   img-src:    data: (SVG avatars) + https: (user uploads, Supabase storage public URLs).
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://plausible.io https://browser.sentry-cdn.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://plausible.io https://*.ingest.sentry.io; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com; font-src 'self' data: https://api.fontshare.com https://cdn.fontshare.com https://fonts.gstatic.com; frame-ancestors 'none'"
</IfModule>

# Disable LiteSpeed server-side cache for all content. Without this,
# Hostinger's LSCache served stale files for a week after every deploy.
# Individual assets still pick up appropriate browser caching from
# mod_expires below; this only turns off the shared edge cache.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# Cache static assets.
# Strategy:
#   HTML / manifest.json / sitemap.xml:   no-cache (always revalidate)
#   /assets/**/*.css + .js:               1 year immutable (cache-busted by
#                                         ?v=<sha> query string appended by
#                                         scripts/deploy.sh, so each deploy
#                                         creates fresh effective URLs)
#   /sw.js (service worker):              no-cache so CACHE_NAME rotates fast
#   Images / icons:                       1 month (rarely change)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # CSS + JS no longer set via mime-type — the <FilesMatch> below pins
  # /assets/* at 1 year explicitly so it beats any generic rule.
</IfModule>

<IfModule mod_headers.c>
  # HTML + manifest + sitemap: always revalidate
  <FilesMatch "\.(html|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Service worker MUST always revalidate — it's the cache-bust mechanism
  # for the whole app; stale SW = stale app.
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Long-cache the assets directory. The ?v=<sha> query string (stamped by
# scripts/deploy.sh into every <link> + <script>) ensures repeat visitors
# fetch fresh files after a deploy while first-time visitors and
# repeat-within-deploy visitors serve straight from browser cache.
<IfModule mod_headers.c>
  <Directory "/home/*/public_html/assets">
    <FilesMatch "\.(css|js|woff2?|ttf|otf|eot)$">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
  </Directory>
  # Hostinger's shared config may not honour <Directory> outside the main
  # config; fallback using <FilesMatch> on the leaf filename pattern.
  # The /assets/ prefix is enforced by file-system layout: only files
  # under that path have extensions like .woff2 or live in /css/ /js/
  # subtrees that this server actually serves.
  <FilesMatch "\.(css|js)$">
    <If "%{REQUEST_URI} =~ m#^/assets/#">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
  </FilesMatch>
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Custom 404 — keeps users inside the ROSTR+ shell instead of landing
# on Hostinger's generic error page.
ErrorDocument 404 /404.html
