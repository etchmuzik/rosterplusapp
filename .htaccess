# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Short URL: rosterplus.io/link → /link.html ───────────────────
# Link-in-bio surface. The "/link" URL is what we publish in Instagram
# bios, business cards, the homepage footer, etc. Internally it's
# served by /link.html. Internal rewrite (no [R]) so the browser bar
# stays at /link — cleaner and more memorable.
RewriteRule ^link/?$ /link.html [L]

# ─── Per-artist Linktree: rosterplus.io/a/<handle> → /a.html ──────
# Every verified artist gets their own Linktree at /a/<handle>. The
# handle column (lower kebab-case derivation of stage_name) was added
# in 20260512_artists_handle.sql.
#
# Two-stage rewrite:
#   1. Link-preview bots (WhatsApp/Slack/etc.) hit a 302-redirect to
#      the profile-share edge function with path=link, so the OG
#      preview contains the artist's actual name + photo + bio.
#      That rule fires FIRST (top-down) because mod_rewrite
#      processes rules in order; [L] on the matching bot rule stops
#      further processing.
#   2. Everyone else gets an internal rewrite to /a.html?h=<handle>.
#      Browser bar stays at the pretty URL.
<IfModule mod_rewrite.c>
  # Stage 1 — bot redirect. UA cond gates whether this fires.
  RewriteCond %{HTTP_USER_AGENT} (WhatsApp|facebookexternalhit|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Embedly|Pinterest|vkShare|redditbot|Skype) [NC]
  RewriteRule ^a/([a-z0-9][a-z0-9\-]{1,31})/?$ https://vgjmfpryobsuboukbemr.supabase.co/functions/v1/profile-share?handle=$1&path=link [R=302,L,NE]

  # Stage 2 — user rewrite. Plain internal forward; query string
  # preserved via [QSA] so any utm / referrer params survive.
  RewriteRule ^a/([a-z0-9][a-z0-9\-]{1,31})/?$ /a.html?h=$1 [L,QSA]
</IfModule>

# ─── Link-preview bots get pre-rendered profile / EPK pages ────────
#
# Why this exists: the app is static HTML + client-side JS. When
# WhatsApp / iMessage / Slack / Twitter / Facebook crawl a
# /profile.html?id=X or /epk.html?id=X link, they read the server
# response BEFORE any JS executes — so every artist link unfurls
# with the same generic OG card. These rules redirect (302) those
# specific crawlers to the `profile-share` Supabase edge function,
# which queries the artist row and returns a tiny HTML doc with
# artist-specific og:title / og:image / og:url. The bot reads the
# meta and stops; the redirect target sets canonical back to
# rosterplus.io so user-facing previews still link here.
#
# We do NOT redirect search-engine crawlers (Googlebot / Bingbot /
# Applebot). Those execute JS, pick up profile.html's updateMeta()
# rewrites, and redirecting them to a different-content URL is SEO
# cloaking — explicitly forbidden by Google's webmaster guidelines.
#
# Uses 302 redirect rather than [P] mod_proxy because Hostinger's
# shared hcdn (LiteSpeed-fronted) isn't reliable about [P] on the
# shared tier. mod_rewrite is proven on this host by the HTTPS
# upgrade rule above.
#
# Per 2026-05-12 profile audit · Option B.
<IfModule mod_rewrite.c>
  # Implementation note: we use %{QUERY_STRING} appended directly
  # to the rule's target, rather than capture-and-extract-uuid. The
  # capture approach hit an Apache mod_rewrite quirk where the
  # `%N` backref only refers to the LAST matched RewriteCond's
  # groups — with three conds stacked, `%2` from the UA cond is
  # the matched UA itself, not the UUID we wanted.
  #
  # Pass-through is also more permissive: any future query params
  # (utm, ?ref=, etc.) flow through to the edge function. The edge
  # function only reads `id` and `path`, so extras are harmless.
  #
  # `[NE]` (no-escape) preserves the literal `&` between original
  # query and our `&path=epk` extension.

  # /profile.html?id=<uuid>
  RewriteCond %{REQUEST_URI}     ^/profile\.html$
  RewriteCond %{QUERY_STRING}    (^|&)id=[a-f0-9\-]+(&|$)
  RewriteCond %{HTTP_USER_AGENT} (WhatsApp|facebookexternalhit|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Embedly|Pinterest|vkShare|redditbot|Skype) [NC]
  RewriteRule ^profile\.html$ https://vgjmfpryobsuboukbemr.supabase.co/functions/v1/profile-share?%{QUERY_STRING} [R=302,L,NE]

  # /epk.html?id=<uuid> — same edge fn with path=epk so canonical
  # points back to /epk.html, not /profile.html.
  RewriteCond %{REQUEST_URI}     ^/epk\.html$
  RewriteCond %{QUERY_STRING}    (^|&)id=[a-f0-9\-]+(&|$)
  RewriteCond %{HTTP_USER_AGENT} (WhatsApp|facebookexternalhit|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Embedly|Pinterest|vkShare|redditbot|Skype) [NC]
  RewriteRule ^epk\.html$ https://vgjmfpryobsuboukbemr.supabase.co/functions/v1/profile-share?%{QUERY_STRING}&path=epk [R=302,L,NE]

  # /booking.html?artist=<uuid> — booking page uses ?artist= (NOT
  # ?id=) per its existing convention. The edge fn accepts both param
  # names, so passing %{QUERY_STRING} through verbatim works. path=booking
  # makes the preview title read "Book <name> — ROSTR+ GCC" and the
  # canonical/og:url point back at /booking.html?artist=…
  RewriteCond %{REQUEST_URI}     ^/booking\.html$
  RewriteCond %{QUERY_STRING}    (^|&)artist=[a-f0-9\-]+(&|$)
  RewriteCond %{HTTP_USER_AGENT} (WhatsApp|facebookexternalhit|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Embedly|Pinterest|vkShare|redditbot|Skype) [NC]
  RewriteRule ^booking\.html$ https://vgjmfpryobsuboukbemr.supabase.co/functions/v1/profile-share?%{QUERY_STRING}&path=booking [R=302,L,NE]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # X-XSS-Protection removed 2026-05-13 audit P2-1 — modern browsers
  # ignore it; older Chrome introduced new XSS vectors via this header
  # in some cases. The CSP below is the correct replacement.
  # Header set X-XSS-Protection "1; mode=block"
  # CSP rationale — only widened to what the app actually needs:
  #   script-src: jsDelivr for Supabase SDK, Plausible for privacy-friendly analytics.
  #   style-src:  Fontshare + Google Fonts stylesheets for Chillax / Satoshi / JetBrains Mono.
  #   font-src:   The actual .woff2 payloads the above stylesheets reference.
  #   connect-src: Supabase API + realtime WebSocket, plus Plausible event endpoint.
  #   img-src:    data: (SVG avatars) + https: (user uploads, Supabase storage public URLs).
  #   frame-src:  oEmbed iframes for the video_links column (2026-05-13) —
  #               YouTube nocookie, Vimeo player, SoundCloud widget,
  #               Mixcloud widget. Instagram embeds are not allowed
  #               (their shim needs broader script-src).
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://plausible.io https://browser.sentry-cdn.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://plausible.io https://*.ingest.sentry.io; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com; font-src 'self' data: https://api.fontshare.com https://cdn.fontshare.com https://fonts.gstatic.com; frame-src 'self' https://www.youtube-nocookie.com https://player.vimeo.com https://w.soundcloud.com https://www.mixcloud.com; frame-ancestors 'none'"
</IfModule>

# Disable LiteSpeed server-side cache for all content. Without this,
# Hostinger's LSCache served stale files for a week after every deploy.
# Individual assets still pick up appropriate browser caching from
# mod_expires below; this only turns off the shared edge cache.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# Cache static assets.
# Strategy:
#   HTML / manifest.json / sitemap.xml:   no-cache (always revalidate)
#   /assets/**/*.css + .js:               1 year immutable (cache-busted by
#                                         ?v=<sha> query string appended by
#                                         scripts/deploy.sh, so each deploy
#                                         creates fresh effective URLs)
#   /sw.js (service worker):              no-cache so CACHE_NAME rotates fast
#   Images / icons:                       1 month (rarely change)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # CSS + JS no longer set via mime-type — the <FilesMatch> below pins
  # /assets/* at 1 year explicitly so it beats any generic rule.
</IfModule>

# Cache-Control headers. Apache merges <FilesMatch> top-to-bottom; when
# patterns overlap the LAST match wins. Order matters here: broad rule
# first (.js/.css long-cache), narrow overrides after (sw.js, HTML).
<IfModule mod_headers.c>
  # Broad rule: every .js/.css/font file gets 1 year immutable. Each
  # deploy's ?v=<sha> query string (stamped by scripts/deploy.sh) makes
  # the URL look new to the browser, so long-cache is safe — repeat
  # visitors in a deploy window fetch zero bytes on the hot path.
  <FilesMatch "\.(css|js|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Narrow override 1: sw.js MUST always revalidate — it's the cache-bust
  # mechanism for the whole app; a stale SW means the whole app is stale.
  # This block must come AFTER the .js rule above for Apache merge-order
  # to resolve correctly.
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Narrow override 2: HTML + manifest + sitemap always revalidate.
  # Lives here to keep all Cache-Control rules in one module-block so
  # the order is obvious at a glance.
  <FilesMatch "\.(html|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Custom 404 — keeps users inside the ROSTR+ shell instead of landing
# on Hostinger's generic error page.
ErrorDocument 404 /404.html
