{
  "name": "rostr-platform",
  "version": "1.0.0",
  "private": true,
  "description": "ROSTR+ GCC — static HTML/JS artist booking platform",
  "scripts": {
    "deploy": "bash scripts/deploy.sh",
    "deploy:dry": "bash scripts/deploy.sh --dry",
    "deploy:full": "bash scripts/deploy.sh --full",
    "test:e2e": "playwright test --config=e2e/playwright.config.js",
    "test:smoke": "playwright test --config=e2e/playwright.config.js --grep @smoke",
    "test:visual": "playwright test --config=e2e/playwright.config.js --grep @visual",
    "test:visual:update": "playwright test --config=e2e/playwright.config.js --grep @visual --update-snapshots",
    "serve": "npx http-server . -p 8090 -c-1 -s"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0"
  }
}
